<UserControl x:Class="PoryectoClienteServidor.Views.Estacionamiento"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:PoryectoClienteServidor.Views"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800" Background="#151D2A">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"></RowDefinition>
            <RowDefinition Height="Auto"></RowDefinition>
            <RowDefinition Height="*"></RowDefinition>
        </Grid.RowDefinitions>
        <Label Grid.Row="0" Foreground="#FFFFFF" Background="#212936" HorizontalContentAlignment="Left" FontSize="16">Reservacion de estacionamiento</Label>
        <Label Grid.Row="1" Foreground="#FFFFFF" HorizontalContentAlignment="Center" FontSize="20">Reservacion de estacionamiento</Label>
        <Grid Grid.Row="2" >
            <Grid.RowDefinitions>
                <RowDefinition Height="auto"></RowDefinition>
                <RowDefinition Height="*"></RowDefinition>
            </Grid.RowDefinitions>
            <Grid Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"></ColumnDefinition>
                    <ColumnDefinition Width="*"></ColumnDefinition>
                </Grid.ColumnDefinitions>
                <Label Grid.Column="0" Foreground="#FFFFFF" BorderThickness="2" BorderBrush="#548C6C" Background="#234930" HorizontalContentAlignment="Center" Margin="10,0,5,0">LUGARES DISPONIBLES: 10</Label>
                <Label Grid.Column="1" Foreground="#FFFFFF" BorderThickness="2" BorderBrush="#925253" Background="#592327" HorizontalContentAlignment="Center" Margin="5,0,10,0">LUGARES DISPONIBLES: 10</Label>
            </Grid>
            <Grid Grid.Row="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"></RowDefinition>
                    <RowDefinition Height="*"></RowDefinition>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"></ColumnDefinition>
                    <ColumnDefinition Width="*"></ColumnDefinition>
                    <ColumnDefinition Width="*"></ColumnDefinition>
                    <ColumnDefinition Width="*"></ColumnDefinition>
                    <ColumnDefinition Width="*"></ColumnDefinition>
                </Grid.ColumnDefinitions>
                <Border Grid.Row="0" Grid.Column="0" BorderBrush="#FFFFFF" BorderThickness="2" Margin="10,10,5,5" Background="#222A37">
                    <StackPanel VerticalAlignment="Center">
                        <Label Foreground="White" HorizontalAlignment="Center" FontSize="30" FontWeight="Bold">1</Label>
                        <Label Foreground="White" HorizontalAlignment="Center" FontSize="15">Libre</Label>
                    </StackPanel>
                </Border>
                <Border Grid.Row="0" Grid.Column="1" BorderBrush="#DE6F7A" BorderThickness="2" Margin="5,10,5,5" Background="#5A2127">
                    <StackPanel VerticalAlignment="Center">
                        <Label Foreground="White" HorizontalAlignment="Center" FontSize="30" FontWeight="Bold">2</Label>
                        <Label Foreground="White" HorizontalAlignment="Center" FontSize="15">Ocupado</Label>
                    </StackPanel>
                </Border>
                <Border Grid.Row="0" Grid.Column="2" BorderBrush="#FFFFFF" BorderThickness="2" Margin="5,10,5,5" Background="#222A37">
                    <StackPanel VerticalAlignment="Center">
                        <Label Foreground="White" HorizontalAlignment="Center" FontSize="30" FontWeight="Bold">3</Label>
                        <Label Foreground="White" HorizontalAlignment="Center" FontSize="15">Libre</Label>
                    </StackPanel>
                </Border>
                <Border Grid.Row="0" Grid.Column="3" BorderBrush="#DE6F7A" BorderThickness="2" Margin="5,10,5,5" Background="#5A2127">
                    <StackPanel VerticalAlignment="Center">
                        <Label Foreground="White" HorizontalAlignment="Center" FontSize="30" FontWeight="Bold">4</Label>
                        <Label Foreground="White" HorizontalAlignment="Center" FontSize="15">Ocupado</Label>
                    </StackPanel>
                </Border>
                <Border Grid.Row="0" Grid.Column="4" BorderBrush="#FFFFFF" BorderThickness="2" Margin="5,10,10,5" Background="#222A37">
                    <StackPanel VerticalAlignment="Center">
                        <Label Foreground="White" HorizontalAlignment="Center" FontSize="30" FontWeight="Bold">5</Label>
                        <Label Foreground="White" HorizontalAlignment="Center" FontSize="15">Libre</Label>
                    </StackPanel>
                </Border>
                <Border Grid.Row="1" Grid.Column="0" BorderBrush="#FFFFFF" BorderThickness="2" Margin="10,5,5,5" Background="#222A37">
                    <StackPanel VerticalAlignment="Center">
                        <Label Foreground="White" HorizontalAlignment="Center" FontSize="30" FontWeight="Bold">6</Label>
                        <Label Foreground="White" HorizontalAlignment="Center" FontSize="15">Libre</Label>
                    </StackPanel>
                </Border>
                <Border Grid.Row="1" Grid.Column="1" BorderBrush="#FFFFFF" BorderThickness="2" Margin="5,5,5,5" Background="#222A37">
                    <StackPanel VerticalAlignment="Center">
                        <Label Foreground="White" HorizontalAlignment="Center" FontSize="30" FontWeight="Bold">7</Label>
                        <Label Foreground="White" HorizontalAlignment="Center" FontSize="15">Libre</Label>
                    </StackPanel>
                </Border>
                <Border Grid.Row="1" Grid.Column="2" BorderBrush="#FFFFFF" BorderThickness="2" Margin="5,5,5,5" Background="#222A37">
                    <StackPanel VerticalAlignment="Center">
                        <Label Foreground="White" HorizontalAlignment="Center" FontSize="30" FontWeight="Bold">8</Label>
                        <Label Foreground="White" HorizontalAlignment="Center" FontSize="15">Libre</Label>
                    </StackPanel>
                </Border>
                <Border Grid.Row="1" Grid.Column="3" BorderBrush="#FFFFFF" BorderThickness="2" Margin="5,5,5,5" Background="#222A37">
                    <StackPanel VerticalAlignment="Center">
                        <Label Foreground="White" HorizontalAlignment="Center" FontSize="30" FontWeight="Bold">9</Label>
                        <Label Foreground="White" HorizontalAlignment="Center" FontSize="15">Libre</Label>
                    </StackPanel>
                </Border>
                <Border Grid.Row="1" Grid.Column="4" BorderBrush="#FFFFFF" BorderThickness="2" Margin="5,5,10,5" Background="#222A37">
                    <StackPanel VerticalAlignment="Center">
                        <Label Foreground="White" HorizontalAlignment="Center" FontSize="30" FontWeight="Bold">10</Label>
                        <Label Foreground="White" HorizontalAlignment="Center" FontSize="15">Libre</Label>
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</UserControl>
